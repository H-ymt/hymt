{
  "name": "hymt",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "tsx scripts/fetch-knowledge.ts && tsx scripts/sync-local-kv.ts && astro dev",
    "build": "tsx scripts/fetch-knowledge.ts && astro build && tsx scripts/dedup-wrangler.ts",
    "preview": "astro build && wrangler dev --config dist/server/wrangler.json",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --fix .",
    "deploy": "pnpm build && wrangler deploy --config dist/server/wrangler.json && pnpm sync-kv",
    "fetch-knowledge": "tsx scripts/fetch-knowledge.ts",
    "sync-kv": "tsx scripts/sync-kv.ts",
    "sync-local-kv": "tsx scripts/sync-local-kv.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.0",
    "astro": "^6.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.4.9",
    "@types/node": "^24.12.2",
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.90.1"
  }
}
