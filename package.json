{
  "name": "hymt",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm fetch-knowledge && next build",
    "build:worker": "npx @opennextjs/cloudflare build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --fix .",
    "deploy": "pnpm build:worker && npx @opennextjs/cloudflare deploy && pnpm sync-kv",
    "preview": "pnpm build:worker && npx @opennextjs/cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "fetch-knowledge": "tsx scripts/fetch-knowledge.ts && tsx scripts/sync-local-kv.ts",
    "sync-kv": "tsx scripts/sync-kv.ts",
    "sync-local-kv": "tsx scripts/sync-local-kv.ts",
    "upload-assets": "tsx scripts/upload-assets.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tanstack/react-query": "^5.95.0",
    "next": "15.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.76.0"
  }
}
