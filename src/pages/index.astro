---
import Container from "../components/Container.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

type BioItem = { id: number; date?: string; body: string };

const bio: BioItem[] = [
  {
    id: 1,
    date: "2017.04",
    body: "First became interested in web and IT after managing websites with a CMS at a government organization, which led me to teach myself web development.",
  },
  {
    id: 2,
    date: "2022.04",
    body: "Began my career as a markup coder at a company that consults for e-commerce sites, working on storefronts for platforms like Rakuten and Yahoo! Shopping.",
  },
  {
    id: 3,
    date: "2024.06",
    body: "Joined a company that develops web systems and websites as a front-end engineer, contributing to projects that build WordPress websites and web systems using Laravel.",
  },
];

const stack = [
  {
    category: "Frontend",
    items: [
      { label: "WordPress", logo: "/logo-wordpress.svg" },
      { label: "JavaScript", logo: "/logo-javascript.svg" },
      { label: "TypeScript", logo: "/logo-typescript.svg" },
      { label: "React", logo: "/logo-react.svg" },
      { label: "Next.js", logo: "/logo-nextjs.svg" },
      { label: "Astro", logo: "/logo-astro.svg" },
      { label: "Sass", logo: "/logo-sass.svg" },
      { label: "Tailwind CSS", logo: "/logo-tailwind-css.svg" },
      { label: "microCMS", logo: "/logo-microcms.svg" },
    ],
  },
  {
    category: "Development Tools",
    items: [
      { label: "Prettier", logo: "/logo-prettier.svg" },
      { label: "Stylelint", logo: "/logo-stylelint.svg" },
      { label: "ESLint", logo: "/logo-eslint.svg" },
      { label: "Biome", logo: "/logo-biome.svg" },
      { label: "npm", logo: "/logo-npm.svg" },
      { label: "pnpm", logo: "/logo-pnpm.svg" },
      { label: "Bun", logo: "/logo-bun.svg" },
      { label: "Vite", logo: "/logo-vite.svg" },
      { label: "Gulp", logo: "/logo-gulp.svg" },
    ],
  },
  {
    category: "Other",
    items: [
      { label: "VSCode", logo: "/logo-vscode.svg" },
      { label: "GitHub", logo: "/logo-github.svg" },
      { label: "Figma", logo: "/logo-figma.svg" },
      { label: "XD", logo: "/logo-xd.svg" },
    ],
  },
];
---

<BaseLayout>
  <Container type="page">
    <h1 class="sr-only">Yamato Handai Personal Website</h1>
    <div class="intro">
      <p class="introHeading">
        A frontend engineer focused on building fast, accessible experiences for the modern web.
      </p>
      <p class="introBody">
        I build websites and web applications using WordPress, React, and modern frontend tools,
        with a strong focus on performance, accessibility, and clean, maintainable code.
      </p>
    </div>

    <section class="section">
      <h2 class="sectionHeading">Biography</h2>
      <ol class="bioList">
        {
          bio.map(({ id, date, body }, index) => (
            <li
              class="bioItem"
              data-current={index === bio.length - 1 ? "true" : "false"}
            >
              {date && (
                <time class="bioDate" datetime={`${date.replace(".", "-")}-01`}>
                  {date}
                </time>
              )}
              <span class="bioBody">{body}</span>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="section">
      <h2 class="sectionHeading">Dotfiles</h2>
      <p class="dotfilesBody">
        My personal development environment configuration, including shell, editor, and CLI
        tooling setup.
      </p>
      <a
        class="dotfilesLink"
        href="https://github.com/H-ymt/dotfiles"
        target="_blank"
        rel="noopener noreferrer"
      >
        github.com/H-ymt/dotfiles
      </a>
    </section>

    <section class="section">
      <h2 class="sectionHeading">What I can do</h2>
      <div class="stackContainer">
        {
          stack.map((s) => (
            <div class="stackCard">
              <h3 class="stackCategory">{s.category}</h3>
              <div class="stackItems">
                {s.items.map((item) => (
                  <div class="stackItem">
                    {item.logo && (
                      <img
                        class="stackLogo"
                        src={item.logo}
                        alt=""
                        width="30"
                        height="30"
                      />
                    )}
                    <p class="stackLabel">{item.label}</p>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </Container>
</BaseLayout>

<style>
  .intro {
    display: grid;
    row-gap: 1rem;
    padding-block: 3rem 2rem;
    text-align: center;
    text-wrap: balance;
  }

  .introHeading {
    font-size: 2rem;
    line-height: 1.3;
    font-weight: 700;
    color: var(--foreground);
  }

  .introBody {
    font-size: 1em;
    color: var(--foreground-muted);
  }

  @media (max-width: 48rem) {
    .intro {
      padding-block: 0;
    }

    .introHeading {
      font-size: 1.5rem;
    }
  }

  .section {
    margin-block-start: 8rem;
  }

  .sectionHeading {
    font-size: 1.125rem;
  }

  .bioList {
    list-style: none;
  }

  .bioItem {
    display: grid;
    gap: 0.125rem;
    padding-block: 0.5em;
    padding-inline-start: 1.5em;
    font-size: 0.9375rem;
    color: var(--foreground-muted);
    border-inline-start: 0.125rem solid var(--border);
  }

  .bioDate {
    margin-block-end: 0.125rem;
    font-size: 0.95em;
  }

  .bioItem[data-current="true"] {
    font-weight: 500;
    color: var(--foreground);
    border-inline-start-color: var(--foreground);
  }

  .dotfilesBody {
    margin-block: 0.875rem 0.75rem;
    font-size: 0.9375rem;
    color: var(--foreground-muted);
  }

  .dotfilesLink {
    font-size: 0.9375rem;
    color: var(--foreground);
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }

  .stackContainer {
    display: grid;
    gap: 3rem;
  }

  .stackCard {
    width: 100%;
  }

  .stackCategory {
    margin-block: 0.75rem 0.875em;
    font-size: 1rem;
    font-weight: 500;
  }

  .stackItems {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(5.5rem, 1fr));
    gap: 2rem;
  }

  .stackItem {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.875rem;
    border-radius: 0.375rem;
  }

  .stackLabel {
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--foreground);
  }
</style>
