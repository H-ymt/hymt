---
import type { KnowledgeEntry, Tag } from "../lib/types";

interface Props {
  initialEntries: KnowledgeEntry[];
  hasMore: boolean;
}

const { initialEntries, hasMore } = Astro.props;

function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return date.toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

{
  initialEntries.length === 0 ? (
    <div class="empty">
      <p>記事がありません。</p>
      <p class="emptySub">
        entries.jsonを生成するには、fetch-knowledgeスクリプトを実行してください。
      </p>
    </div>
  ) : (
    <section class="section">
      <ul
        class="entryList"
        id="entry-list"
        data-has-more={hasMore ? "true" : "false"}
        data-page="1"
      >
        {initialEntries.map((entry: KnowledgeEntry) => (
          <li class="entryItem">
            <article class="entry">
              <header class="entryHeader">
                <div class="entryMeta">
                  <time class="entryDate" datetime={entry.publishedAt}>
                    {formatDate(entry.publishedAt)}
                  </time>
                </div>
                <h2 class="entryTitle">
                  <span class="entrySource">
                    {entry.source === "gist" ? (
                      <svg
                        class="sourceIcon"
                        viewBox="0 0 16 16"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
                      </svg>
                    ) : (
                      <svg
                        class="sourceIcon"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M.264 23.771h4.984c.264 0 .498-.147.645-.352L19.614.874c.176-.293-.029-.645-.381-.645h-4.72c-.235 0-.44.117-.557.323L.03 23.361c-.088.176.029.41.234.41zM17.445 23.419l6.479-10.408c.205-.323-.029-.733-.41-.733h-4.691c-.176 0-.352.088-.44.235l-6.655 10.643c-.176.264.029.616.352.616h4.779c.234-.001.468-.118.586-.353z" />
                      </svg>
                    )}
                  </span>
                  <a
                    href={entry.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="entryLink"
                  >
                    {entry.title}
                    <svg
                      class="externalIcon"
                      width="11"
                      height="11"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M13 5H19V11" />
                      <path d="M19 5L5 19" />
                    </svg>
                  </a>
                </h2>
              </header>
              {entry.summary && <p class="entrySummary">{entry.summary}</p>}
              {entry.tags.length > 0 && (
                <ul class="tagList">
                  {entry.tags.map((tag: Tag) => (
                    <li class="tag">{tag}</li>
                  ))}
                </ul>
              )}
            </article>
          </li>
        ))}
      </ul>
      <div id="observer-target" class="observerTarget">
        <div id="loading-container" class="loadingContainer" hidden>
          <svg
            class="spinner"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10" opacity="0.25" />
            <path
              d="M12 2a10 10 0 0 1 10 10"
              opacity="0.75"
              stroke-dasharray="31.416"
              stroke-dashoffset="31.416"
            >
              <animate
                attributeName="stroke-dashoffset"
                dur="1.5s"
                values="31.416;0"
                repeatCount="indefinite"
              />
            </path>
          </svg>
          <p class="loading">読み込み中...</p>
        </div>
      </div>
    </section>
  )
}

<script>
  type EntryData = {
    id: string;
    source: "gist" | "zenn";
    title: string;
    url: string;
    publishedAt: string;
    summary?: string;
    tags: string[];
  };

  function buildGistIcon(): SVGSVGElement {
    const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
    svg.setAttribute("viewBox", "0 0 16 16");
    svg.setAttribute("fill", "currentColor");
    svg.setAttribute("aria-hidden", "true");
    svg.style.cssText = "width:1rem;height:1rem;color:var(--foreground-muted);";
    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
    path.setAttribute(
      "d",
      "M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z",
    );
    svg.appendChild(path);
    return svg;
  }

  function buildZennIcon(): SVGSVGElement {
    const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
    svg.setAttribute("viewBox", "0 0 24 24");
    svg.setAttribute("fill", "currentColor");
    svg.setAttribute("aria-hidden", "true");
    svg.style.cssText = "width:1rem;height:1rem;color:var(--foreground-muted);";
    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
    path.setAttribute(
      "d",
      "M.264 23.771h4.984c.264 0 .498-.147.645-.352L19.614.874c.176-.293-.029-.645-.381-.645h-4.72c-.235 0-.44.117-.557.323L.03 23.361c-.088.176.029.41.234.41zM17.445 23.419l6.479-10.408c.205-.323-.029-.733-.41-.733h-4.691c-.176 0-.352.088-.44.235l-6.655 10.643c-.176.264.029.616.352.616h4.779c.234-.001.468-.118.586-.353z",
    );
    svg.appendChild(path);
    return svg;
  }

  function buildExternalIcon(): SVGSVGElement {
    const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
    svg.setAttribute("viewBox", "0 0 24 24");
    svg.setAttribute("fill", "none");
    svg.setAttribute("stroke", "currentColor");
    svg.setAttribute("stroke-width", "2");
    svg.setAttribute("stroke-linecap", "round");
    svg.setAttribute("stroke-linejoin", "round");
    svg.setAttribute("aria-hidden", "true");
    svg.style.cssText =
      "width:0.6875rem;height:0.6875rem;margin-inline-start:0.375rem;vertical-align:middle;opacity:0.6;transition:opacity 0.2s;";
    const p1 = document.createElementNS("http://www.w3.org/2000/svg", "path");
    p1.setAttribute("d", "M13 5H19V11");
    const p2 = document.createElementNS("http://www.w3.org/2000/svg", "path");
    p2.setAttribute("d", "M19 5L5 19");
    svg.appendChild(p1);
    svg.appendChild(p2);
    return svg;
  }

  function buildEntryItem(entry: EntryData): HTMLLIElement {
    const li = document.createElement("li");
    li.style.cssText = "padding-block-end:2rem;border-bottom:0.0313rem solid var(--border);";

    const article = document.createElement("article");
    article.style.cssText = "display:flex;flex-direction:column;gap:0.75rem;";

    const header = document.createElement("header");
    header.style.cssText = "display:flex;flex-direction:column;gap:0.5rem;";

    const meta = document.createElement("div");
    meta.style.cssText =
      "display:flex;gap:0.75rem;align-items:center;font-size:0.875rem;color:var(--foreground-muted);";
    const time = document.createElement("time");
    time.style.cssText = "font-size:0.875rem;";
    time.setAttribute("datetime", entry.publishedAt);
    time.textContent = new Date(entry.publishedAt).toLocaleDateString("ja-JP", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
    meta.appendChild(time);

    const h2 = document.createElement("h2");
    h2.style.cssText = "margin:0;font-size:0.9375rem;font-weight:500;";

    const sourceSpan = document.createElement("span");
    sourceSpan.style.cssText = "margin-inline-end:0.375rem;vertical-align:middle;";
    sourceSpan.appendChild(entry.source === "gist" ? buildGistIcon() : buildZennIcon());

    const link = document.createElement("a");
    link.href = entry.url;
    link.target = "_blank";
    link.rel = "noopener noreferrer";
    link.style.cssText = "color:var(--foreground);text-decoration:none;";
    link.textContent = entry.title;
    link.appendChild(buildExternalIcon());

    h2.appendChild(sourceSpan);
    h2.appendChild(link);
    header.appendChild(meta);
    header.appendChild(h2);
    article.appendChild(header);

    if (entry.summary) {
      const p = document.createElement("p");
      p.style.cssText =
        "margin:0;font-size:0.875rem;line-height:1.6;color:var(--foreground-muted);";
      p.textContent = entry.summary;
      article.appendChild(p);
    }

    if (entry.tags.length > 0) {
      const ul = document.createElement("ul");
      ul.style.cssText = "display:flex;flex-wrap:wrap;gap:0.5rem;margin:0;list-style:none;";
      for (const tag of entry.tags) {
        const tagLi = document.createElement("li");
        tagLi.style.cssText =
          "display:inline-block;padding:0.125rem 0.5rem;font-size:0.75rem;color:var(--foreground-muted);background-color:var(--border);border-radius:0.25rem;";
        tagLi.textContent = tag;
        ul.appendChild(tagLi);
      }
      article.appendChild(ul);
    }

    li.appendChild(article);
    return li;
  }

  const list = document.getElementById("entry-list") as HTMLUListElement | null;
  const target = document.getElementById("observer-target");
  const loadingContainer = document.getElementById("loading-container");

  if (list && target) {
    let page = parseInt(list.dataset.page ?? "1", 10);
    let hasMore = list.dataset.hasMore === "true";
    let isFetching = false;

    async function loadMore() {
      if (!hasMore || isFetching) return;
      isFetching = true;
      if (loadingContainer) (loadingContainer as HTMLElement).hidden = false;

      try {
        const nextPage = page + 1;
        const res = await fetch(`/api/entries?page=${nextPage}&limit=10`);
        if (!res.ok) throw new Error("Failed to fetch");

        const data = (await res.json()) as {
          entries: EntryData[];
          hasMore: boolean;
        };

        for (const entry of data.entries) {
          list.appendChild(buildEntryItem(entry));
        }

        page = nextPage;
        hasMore = data.hasMore;
        if (!hasMore) observer.disconnect();
      } catch (e) {
        console.error(e);
      } finally {
        isFetching = false;
        if (loadingContainer) (loadingContainer as HTMLElement).hidden = true;
      }
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0]?.isIntersecting) loadMore();
      },
      { threshold: 0.8 },
    );

    if (hasMore) observer.observe(target);
  }
</script>

<style>
  .section {
    margin-block-start: 2rem;
  }

  .empty {
    padding-block: 4rem;
    color: var(--foreground-muted);
    text-align: center;
  }

  .emptySub {
    margin-block-start: 0.5rem;
    font-size: 0.875rem;
  }

  .entryList {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    list-style: none;
  }

  .entryItem {
    padding-block-end: 2rem;
    border-bottom: 0.0313rem solid var(--border);
  }

  .entryItem:last-child {
    border-bottom: none;
  }

  .entry {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .entryHeader {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .entryMeta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.875rem;
    color: var(--foreground-muted);
  }

  .entryDate {
    font-size: 0.875rem;
  }

  .entryTitle {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 500;
  }

  .entrySource {
    margin-inline-end: 0.375rem;
    vertical-align: middle;
  }

  .sourceIcon {
    width: 1rem;
    height: 1rem;
    color: var(--foreground-muted);
  }

  .entryLink {
    color: var(--foreground);
    text-decoration: none;
    transition: text-decoration 0.2s;
  }

  .entryLink:hover {
    text-decoration: underline;
    text-decoration-thickness: 0.0625rem;
    text-underline-offset: 0.125rem;
  }

  .externalIcon {
    width: 0.6875rem;
    height: 0.6875rem;
    margin-inline-start: 0.35rem;
    margin-block-end: 0.15em;
    vertical-align: middle;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .entryLink:hover .externalIcon {
    opacity: 1;
  }

  .entrySummary {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--foreground-muted);
  }

  .tagList {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    list-style: none;
  }

  .tag {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    color: var(--foreground-muted);
    background-color: var(--border);
    border-radius: 0.25rem;
  }

  @media (max-width: 48rem) {
    .entryList {
      gap: 1.5rem;
    }

    .entryItem {
      padding-block-end: 1.5rem;
    }
  }

  .observerTarget {
    padding-block: 2rem;
    margin-block-start: 2rem;
    text-align: center;
  }

  .loadingContainer {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }

  .spinner {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--foreground-muted);
    animation: spin 1.5s linear infinite;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .loading {
    font-size: 0.875rem;
    color: var(--foreground-muted);
  }
</style>
